{
	"name": "api",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently \"tsc --watch --noEmit\" \"nodemon\"",
		"build": "rm -rf build && tsc --project tsconfig.build.json && tsc-alias -p tsconfig.build.json",
		"postbuild": "tsx scripts/postbuild.ts",
		"start": "node build/main.js",
		"typecheck": "tsc --project tsconfig.json --noEmit",
		"check": "pnpm run typecheck && pnpm run lint",
		"lint": "eslint .",
		"format": "prettier --experimental-cli --write ."
	},
	"lint-staged": {
		"*.{js,ts}": [
			"eslint",
			"prettier --experimental-cli --write"
		],
		"*.{json,md}": "prettier --experimental-cli --write"
	},
	"dependencies": {
		"dotenv": "^17.4.2",
		"express": "^5.2.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@packages/eslint-config": "workspace:*",
		"@packages/prettier-config": "workspace:*",
		"@types/express": "^5.0.6",
		"concurrently": "^10.0.3",
		"nodemon": "^3.1.14",
		"tsc-alias": "^1.8.17"
	}
}
