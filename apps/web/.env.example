# Web configuration — copy this file to .env and fill in your values
# SvelteKit exposes env vars prefixed with PUBLIC_ to the browser.
# See https://svelte.dev/docs/kit/$env-static-public

# Public API URL (accessible from the browser)
PUBLIC_API_URL=http://localhost:8000

# Adapter-node production URL (uncomment for deployment)
# ORIGIN=https://your-production-domain.com
