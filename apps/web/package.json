{
	"name": "web",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"start": "node build",
		"build": "rm -rf build && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"sv:check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && eslint .",
		"lint": "eslint .",
		"format": "prettier --experimental-cli --write ."
	},
	"lint-staged": {
		"*.{js,ts,svelte}": [
			"eslint",
			"prettier --experimental-cli --write"
		],
		"*.{json,css,md}": "prettier --experimental-cli --write"
	},
	"devDependencies": {
		"@packages/eslint-config": "workspace:*",
		"@packages/prettier-config": "workspace:*",
		"@sveltejs/adapter-node": "^5.5.6",
		"@sveltejs/kit": "^2.67.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.1",
		"eslint-plugin-svelte": "^3.19.0",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"tailwindcss": "^4.3.1",
		"vite": "^8.1.0"
	}
}
