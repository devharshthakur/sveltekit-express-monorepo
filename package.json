{
  "name": "sveltekit-express-monorepo",
  "version": "1.2.1",
  "private": true,
  "description": "A sveltekit + express monorepo starter template",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devharshthakur/sveltekit-express-monorepo.git"
  },
  "bugs": {
    "url": "https://github.com/devharshthakur/sveltekit-express-monorepo/issues"
  },
  "homepage": "https://github.com/devharshthakur/sveltekit-express-monorepo#readme",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run build && turbo run start",
    "preview": "turbo run preview",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "turbo run check",
    "prepare": "husky",
    "docker:start": "docker compose up -d --build",
    "deps:outdated": "tsx scripts/outdated.ts",
    "deps:update": "tsx scripts/update.ts",
    "changelog": "changelogen --no-output",
    "test:setup": "bash test-setup.sh"
  },
  "keywords": [],
  "author": {
    "name": "Harsh Thakur",
    "email": "harshprojects2002@gmail.com",
    "url": "https://www.devht.in/"
  },
  "license": "MIT",
  "packageManager": "pnpm@11.6.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "lint-staged": {
    "*.{json,yml,yaml,md}": "prettier --write"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "changelogen": "^0.6.2",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "turbo": "^2.10.3",
    "typescript": "^6.0.3"
  }
}
